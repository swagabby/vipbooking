<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SWAG VIP Welfare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background: #0a0a0a; color: #eee; font-family: 'PingFang TC', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); }
        .benefit-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
        .benefit-card:hover:not(.locked) { transform: translateY(-5px); border-color: #ff5a5f; background: rgba(255, 90, 95, 0.05); }
        .locked { opacity: 0.4; cursor: not-allowed; filter: grayscale(1); }
        .skeleton { background: linear-gradient(90deg, #1a1a1a 25%, #2a2a2a 50%, #1a1a1a 75%); background-size: 200% 100%; animation: loading 1.5s infinite; }
        @keyframes loading { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    </style>
</head>
<body class="p-4 md:p-8">

    <!-- 多語系切換 -->
    <div class="fixed top-4 right-4 z-50 flex gap-2">
        <button onclick="setLang('zh')" class="text-xs glass px-2 py-1 rounded">繁</button>
        <button onclick="setLang('en')" class="text-xs glass px-2 py-1 rounded">EN</button>
    </div>

    <div class="max-w-2xl mx-auto">
        <header class="text-center mb-10">
            <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500">VIP 預約系統</h1>
            <p id="user-display" class="text-gray-400 mt-2 text-sm">正在核對身份...</p>
        </header>

        <!-- Skeleton Loading -->
        <div id="loading-skeleton" class="space-y-4">
            <div class="skeleton h-32 rounded-2xl"></div>
            <div class="skeleton h-32 rounded-2xl"></div>
            <div class="skeleton h-32 rounded-2xl"></div>
        </div>

        <!-- 福利列表 -->
        <div id="benefit-container" class="grid grid-cols-1 gap-4 hidden">
            <!-- 由 JS 動態渲染 -->
        </div>
    </div>

    <!-- 預約表單 Modal (範例) -->
    <div id="modal" class="fixed inset-0 bg-black/80 hidden items-center justify-center p-4 z-50">
        <div class="glass w-full max-w-md p-6 rounded-3xl">
            <h2 id="modal-title" class="text-xl font-bold mb-4"></h2>
            <div class="space-y-4">
                <div>
                    <label class="text-xs text-gray-400">主播 ID</label>
                    <input type="text" id="anchor_id" class="w-full bg-white/5 border border-white/10 rounded-xl p-3 mt-1 focus:border-[#ff5a5f] outline-none">
                </div>
                <div>
                    <label class="text-xs text-gray-400">預約日期</label>
                    <input type="date" id="reserve_date" class="w-full bg-white/5 border border-white/10 rounded-xl p-3 mt-1 outline-none">
                </div>
                <button onclick="submitForm()" class="w-full bg-[#ff5a5f] text-white py-4 rounded-xl font-bold hover:bg-[#ff454a] transition-all">確認送出</button>
                <button onclick="closeModal()" class="w-full text-gray-500 text-sm py-2">取消</button>
            </div>
        </div>
    </div>

    <script>
        // 配置你的 GAS API URL
        const GAS_API_URL = 'https://script.google.com/macros/s/AKfycbxlMEEW3k4D8ABAlPK4WdGmNk3CC1s4mMxZP06Sfy8bm2ZcQPXIJ006RkSca9k0W7D-Ug/exec';
        
        let currentUser = { id: '', level: 0 };
        const BENEFITS = [
            { id: 'grand', name: '大神贊助', lv: 50, desc: '心儀創作者直播間高度曝光' },
            { id: 'party', name: '女神聚會', lv: 50, desc: '參加線下高質感聚會' },
            { id: 'bell', name: '訂製小鈴噹', lv: 60, desc: '客製化推播通知' },
            { id: 'cover', name: '全站蓋板封面', lv: 70, desc: '首次進入平台跳出曝光' },
            { id: 'search', name: '搜尋框文字', lv: 70, desc: '打造專屬熱搜字' },
            { id: 'gift', name: '訂製專屬禮物', lv: 80, desc: '直播間專屬動畫禮物' },
            { id: 'ad', name: '專屬直播欄位廣告', lv: 90, desc: '探索頁面焦點曝光' }
        ];

        async function init() {
            const params = new URLSearchParams(window.location.search);
            currentUser.id = params.get('user_id') || 'GUEST';

            try {
                const response = await fetch(`${GAS_API_URL}?action=getUser&user_id=${currentUser.id}`);
                const data = await response.json();
                currentUser.level = data.level;
                
                document.getElementById('user-display').innerText = `ID: ${currentUser.id} | Level: ${currentUser.level}`;
                renderBenefits();
            } catch (e) {
                document.getElementById('user-display').innerText = '無法載入用戶資料';
            } finally {
                document.getElementById('loading-skeleton').classList.add('hidden');
                document.getElementById('benefit-container').classList.remove('hidden');
            }
        }

        function renderBenefits() {
            const container = document.getElementById('benefit-container');
            container.innerHTML = BENEFITS.map(b => `
                <div class="benefit-card glass p-6 rounded-2xl flex justify-between items-center ${currentUser.level < b.lv ? 'locked' : ''}" 
                     onclick="${currentUser.level >= b.lv ? `openModal('${b.name}')` : ''}">
                    <div>
                        <span class="text-[10px] bg-white/10 px-2 py-0.5 rounded-full text-gray-400">LV.${b.lv}+</span>
                        <h3 class="text-lg font-bold mt-1">${b.name}</h3>
                        <p class="text-sm text-gray-500">${b.desc}</p>
                    </div>
                    ${currentUser.level < b.lv ? '🔒' : '<span class="text-[#ff5a5f]">→</span>'}
                </div>
            `).join('');
        }

        let currentBenefit = '';
        function openModal(name) {
            currentBenefit = name;
            document.getElementById('modal-title').innerText = name;
            document.getElementById('modal').classList.remove('hidden');
            document.getElementById('modal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('modal').classList.add('hidden');
            document.getElementById('modal').classList.remove('flex');
        }

        async function submitForm() {
            const payload = {
                user_id: currentUser.id,
                level: currentUser.level,
                benefit: currentBenefit,
                anchor_id: document.getElementById('anchor_id').value,
                date: document.getElementById('reserve_date').value
            };

            if (!payload.anchor_id || !payload.date) return alert('請完整填寫');

            // 呼叫 GAS POST API
            const res = await fetch(GAS_API_URL, {
                method: 'POST',
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            alert(result.message);
            if (result.success) location.reload();
        }

        init();
    </script>
</body>
</html>
