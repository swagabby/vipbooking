<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <style>
    :root {
      --primary: #FF5A5F;
      --bg: #0D0D0D;
      --card-bg: rgba(255, 255, 255, 0.05);
      --glass: rgba(255, 255, 255, 0.1);
      --text: #FFFFFF;
    }
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, sans-serif;
      margin: 0; padding: 20px;
      display: flex; flex-direction: column; align-items: center;
    }
    .container { width: 100%; max-width: 500px; }
    
    /* 毛玻璃卡片 */
    .benefit-card {
      background: var(--card-bg);
      backdrop-filter: blur(10px);
      border: 1px solid var(--glass);
      border-radius: 16px;
      padding: 20px; margin-bottom: 15px;
      transition: transform 0.2s;
      cursor: pointer;
      position: relative;
    }
    .benefit-card.locked { opacity: 0.5; filter: grayscale(1); cursor: not-allowed; }
    .benefit-card:hover:not(.locked) { transform: translateY(-5px); border-color: var(--primary); }
    
    .badge {
      position: absolute; top: 10px; right: 10px;
      background: var(--primary); font-size: 10px; padding: 2px 8px; border-radius: 10px;
    }

    /* Skeleton Loading */
    .skeleton {
      background: linear-gradient(90deg, #222 25%, #333 50%, #222 75%);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
      height: 100px; border-radius: 16px; margin-bottom: 15px;
    }
    @keyframes loading { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    .header { text-align: center; margin-bottom: 30px; }
    .lang-selector { position: absolute; top: 10px; right: 10px; display: flex; gap: 5px; }
    .lang-btn { background: none; border: 1px solid var(--glass); color: #ccc; font-size: 10px; cursor: pointer; }

    input, select, textarea {
      width: 100%; background: #222; border: 1px solid var(--glass);
      color: white; padding: 12px; border-radius: 8px; margin-top: 10px; box-sizing: border-box;
    }
    .submit-btn {
      background: var(--primary); color: white; border: none; width: 100%;
      padding: 15px; border-radius: 8px; font-weight: bold; margin-top: 20px; cursor: pointer;
    }
  </style>
</head>
<body>

  <div class="lang-selector">
    <button class="lang-btn" onclick="setLang('zh')">繁</button>
    <button class="lang-btn" onclick="setLang('en')">EN</button>
  </div>

  <div class="container">
    <div class="header">
      <h1 id="title">SWAG VIP 預約系統</h1>
      <p id="user-info">載入中...</p>
    </div>

    <div id="loading-view">
      <div class="skeleton"></div>
      <div class="skeleton"></div>
      <div class="skeleton"></div>
    </div>

    <div id="main-view" style="display:none;">
      <!-- 福利卡片將由 JS 動態生成 -->
      <div id="benefit-list"></div>
    </div>

    <!-- 預約表單 Modal (簡化版) -->
    <div id="form-view" style="display:none;">
      <button onclick="showList()" style="color: #aaa; background:none; border:none; cursor:pointer;">← 返回</button>
      <h2 id="form-title"></h2>
      <div id="dynamic-form">
        <input type="text" id="anchor_id" placeholder="請輸入主播 ID">
        <input type="date" id="reserve_date">
        <textarea id="content" placeholder="客製化文字或備註"></textarea>
        <button class="submit-btn" onclick="handlePreview()">預覽並送出</button>
      </div>
    </div>
  </div>

  <script>
    let currentUser = { id: '', level: 0 };
    const BENEFITS = [
      { name: "大神贊助", lv: 50, type: "date" },
      { name: "女神聚會", lv: 50, type: "select" },
      { name: "訂製小鈴噹通知", lv: 60, type: "date" },
      { name: "蓋板創作者封面", lv: 70, type: "date" },
      { name: "訂製搜尋框文字", lv: 70, type: "date" },
      { name: "訂製專屬徽章", lv: 80, type: "input" },
      { name: "訂製專屬禮物", lv: 80, type: "input" },
      { name: "專屬直播欄位廣告", lv: 90, type: "date" }
    ];

    window.onload = () => {
      // 從 URL 取得 user_id
      const urlParams = new URLSearchParams(window.location.search);
      currentUser.id = urlParams.get('user_id') || 'TEST_USER';
      
      google.script.run.withSuccessHandler(data => {
        currentUser.level = data.level;
        document.getElementById('user-info').innerText = `User ID: ${currentUser.id} | Level: ${currentUser.level}`;
        renderBenefits();
        document.getElementById('loading-view').style.display = 'none';
        document.getElementById('main-view').style.display = 'block';
      }).getUserData(currentUser.id);
    };

    function renderBenefits() {
      const list = document.getElementById('benefit-list');
      list.innerHTML = '';
      BENEFITS.forEach(b => {
        const isLocked = currentUser.level < b.lv;
        const div = document.createElement('div');
        div.className = `benefit-card ${isLocked ? 'locked' : ''}`;
        div.innerHTML = `
          <div class="badge">Lv.${b.lv}+</div>
          <h3>${b.name}</h3>
          <p>${isLocked ? '尚未解鎖' : '點擊開始預約'}</p>
        `;
        if (!isLocked) div.onclick = () => openForm(b);
        list.appendChild(div);
      });
    }

    let selectedBenefit = null;
    function openForm(b) {
      selectedBenefit = b;
      document.getElementById('main-view').style.display = 'none';
      document.getElementById('form-view').style.display = 'block';
      document.getElementById('form-title').innerText = b.name;
    }

    function showList() {
      document.getElementById('form-view').style.display = 'none';
      document.getElementById('main-view').style.display = 'block';
    }

    function handlePreview() {
      const data = {
        user_id: currentUser.id,
        level: currentUser.level,
        benefit: selectedBenefit.name,
        anchor_id: document.getElementById('anchor_id').value,
        date: document.getElementById('reserve_date').value,
        content: document.getElementById('content').value
      };
      
      if (!data.anchor_id) { alert('請填寫主播 ID'); return; }

      google.script.run.withSuccessHandler(res => {
        alert(res.message);
        if (res.success) window.location.reload();
      }).submitReservation(data);
    }
  </script>
</body>
</html>
